# Cloudflare Pages Functions server-side secrets for local development.
# Copy to `.dev.vars` when using `wrangler pages dev` or set the same values as
# production/staging secrets in the Cloudflare Pages dashboard.
#
# Keep these server-only. Never prefix them with VITE_ and never expose them to the client.

# Provider precedence: if both keys are set, the chat function uses OpenAI.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Chat persistence uses the same Supabase worker secrets as the site form handlers.
SUPABASE_URL=
SUPABASE_KEY=

# Encrypts per-user exchange API keys saved by /trading/save-keys.
# Generate a long random value, keep it stable, and do not commit real values:
# openssl rand -base64 32
TRADING_KEYS_ENCRYPTION_KEY=

# LeadBot platform credentials.
# Store long-lived server-side access tokens plus app IDs/secrets required by each platform.

# Meta / Facebook Lead Ads
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_PAGE_ID=

# Instagram Graph
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_VERIFY_TOKEN=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_PAGE_ID=

# TikTok For Business
TIKTOK_APP_ID=
# Store the TikTok client secret here; the webhook handler uses it to validate TikTok-Signature.
TIKTOK_APP_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=
TIKTOK_PAGE_ID=
TIKTOK_LEAD_LOOKBACK_DAYS=30

# Trading exchange credentials.
# Keep these server-only. Do not prefix them with VITE_, do not commit real values,
# and create exchange keys without withdrawal permissions.
TRADING_EXCHANGE_ID=binance
TRADING_DEFAULT_SYMBOL=BTC/USDT
TRADING_TRADE_LIMIT=50

BINANCE_API_KEY=
BINANCE_SECRET=
# Optional; enables ccxt sandbox mode when the exchange supports it.
BINANCE_SANDBOX=false

# Optional generic fallback names for non-Binance exchanges. Prefer exchange-prefixed
# names such as KRAKEN_API_KEY/KRAKEN_SECRET or OKX_API_KEY/OKX_SECRET in production.
TRADING_API_KEY=
TRADING_SECRET=
TRADING_PASSWORD=
TRADING_UID=
