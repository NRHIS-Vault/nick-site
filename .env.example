# Supabase project URL for auth/data access from the client.
VITE_SUPABASE_URL=
# Supabase anon/public API key used by the client SDK.
VITE_SUPABASE_ANON_KEY=
# Stripe publishable key for client-side checkout/payment flows.
VITE_STRIPE_PK=
# Base URL for your backend/worker API that powers dashboard calls.
VITE_API_BASE=

# Do not place LLM secrets in this file.
# Server-only chat keys belong in Cloudflare Pages secrets or a local .dev.vars file.
